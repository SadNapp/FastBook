<Window x:Class="FastBook.Views.NoteWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FastBook Notes" Height="450" Width="350"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False" WindowStartupLocation="Manual">

    <Border CornerRadius="20" BorderThickness="1.5" BorderBrush="#40FFFFFF">
        <Border.Background>
            <SolidColorBrush Color="#1A1A1A" Opacity="0.95"/>
        </Border.Background>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="35"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="35"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Background="Transparent" MouseLeftButtonDown="HeaderBar_MouseLeftButtonDown">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="15,0">
                    <Ellipse x:Name="PriorityEllipse" Width="8" Height="8" Fill="Green" Margin="0,0,8,0"/>
                    <TextBlock x:Name="ClockTextBlock" Text="00:00:00" Foreground="#AAFFFFFF" FontSize="11"/>
                </StackPanel>
                <Button Content="✕" HorizontalAlignment="Right" Width="35" Background="Transparent" 
                        Foreground="White" BorderThickness="0" Click="CloseButton_Click" Cursor="Hand"/>
            </Grid>

            <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0" Margin="5,0" 
                        SelectionChanged="CategoryTab_SelectionChanged">
                <TabControl.Resources>
                    <Style TargetType="TabItem">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="TabItem">
                                    <Border x:Name="Border" Margin="2,2" Padding="8,4" CornerRadius="8">
                                        <ContentPresenter ContentSource="Header"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Border" Property="Background" Value="#30FFFFFF"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="False">
                                            <Setter Property="Foreground" Value="#80FFFFFF"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </TabControl.Resources>
                <TabItem Header="Default"/>
                <TabItem Header="Home"/>
                <TabItem Header="Work"/>
                <TabItem Header="Everyday"/>
                <TabItem Header="Finance"/>
            </TabControl>

            <Grid Grid.Row="2" Margin="10,5">
                <Rectangle RadiusX="12" RadiusY="12" Fill="#0FFFFFFF"/>
                <ScrollViewer x:Name="NoteScrollViewer" VerticalScrollBarVisibility="Auto">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="35"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock x:Name="LineNumbersBlock" Grid.Column="0" Padding="0,10,8,0" 
                                   Text="1" Foreground="#30FFFFFF" FontSize="13" 
                                   TextAlignment="Right" FontFamily="Consolas"/>

                        <TextBox x:Name="NoteTextBox" Grid.Column="1" Background="Transparent" 
                                 Foreground="White" BorderThickness="0" TextWrapping="NoWrap" 
                                 AcceptsReturn="True" Padding="5,10,10,10" FontSize="14" 
                                 CaretBrush="White" FontFamily="Consolas" 
                                 TextChanged="NoteTextBox_TextChanged" VerticalScrollBarVisibility="Hidden"/>
                    </Grid>
                </ScrollViewer>
            </Grid>

            <Grid Grid.Row="3" Margin="15,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <TextBlock Text="Priority: " Foreground="#50FFFFFF" VerticalAlignment="Center" FontSize="10" Width="35"/>
                    <ComboBox x:Name="PriorityComboBox" Width="71" Height="18" FontSize="9"
                              SelectionChanged="Priority_Changed" Background="#FF232222" OpacityMask="Black">
                        <ComboBoxItem Content="Low" Tag="1"/>
                        <ComboBoxItem Content="Mid" Tag="2"/>
                        <ComboBoxItem Content="High" Tag="3"/>
                    </ComboBox>
                </StackPanel>

                <Button x:Name="SettingsButton" Content="⚙ Налаштування" HorizontalAlignment="Right" 
                        Background="Transparent" Foreground="#60FFFFFF" BorderThickness="0" 
                        FontSize="10" Click="Settings_Click" Cursor="Hand"/>
            </Grid>

            <Popup x:Name="SettingsPopup" StaysOpen="False" Placement="Top" 
                   PlacementTarget="{Binding ElementName=SettingsButton}" VerticalOffset="-5">
                <Border Background="#252525" CornerRadius="12" Padding="12" 
                        BorderThickness="1" BorderBrush="#30FFFFFF">
                    <StackPanel Width="160">
                        <CheckBox x:Name="PinCheckBox" Content="Поверх вікон" Foreground="White" 
                                  IsChecked="True" Checked="Pin_Checked" Unchecked="Pin_Unchecked" Margin="0,4"/>

                        <CheckBox x:Name="TimeCheckBox" Content="Показати час" Foreground="White" 
                                  IsChecked="True" Checked="Time_Checked" Unchecked="Time_Unchecked" Margin="0,4"/>

                        <Separator Background="#20FFFFFF" Margin="0,8"/>

                        <TextBlock Text="Розмір шрифту" Foreground="#60FFFFFF" FontSize="9" Margin="0,0,0,5"/>
                        <Slider Minimum="10" Maximum="22" Value="14" 
                                ValueChanged="FontSize_Changed" IsSnapToTickEnabled="True" TickFrequency="1"/>
                    </StackPanel>
                </Border>
            </Popup>
        </Grid>
    </Border>
</Window>